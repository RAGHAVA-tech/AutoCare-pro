# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Optional — only needed if you connect a real Postgres database.
# If unset, the app automatically falls back to a local SQLite file
# (./autocare.db), which is fine for a single-machine demo/pilot.
# DATABASE_URL="postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME"

# Optional — only needed if/when you wire up a real voice provider.
SOUNDHOUND_API_KEY=""
SOUNDHOUND_CLIENT_ID=""

# Passcode that gates the Staff/Admin pages in streamlit_app.py
# (CRM Lookup, Phone Simulation, Dashboard, Customer Directory).
# CHANGE THIS before deploying — the app falls back to "changeme" if unset.
STAFF_PASSCODE="change-me-to-something-strong"
